# === SUOSITUS: paras suomen puheentunnistus + GPU (RTX 4050 ym.) ===
ASR_MODEL_SIZE=large-v3
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_BEAM_SIZE=5
ASR_BEST_OF=5
TRANSLATE_DEVICE=cuda
TRANSLATION_ENGINE=hybrid
TRANSLATE_NUM_BEAMS=4

# ASENNUS VAIN backend\.venv (ei koneen Pythonia). Aja backend-kansiosta:
#   .\setup.ps1
#   .\install_torch_gpu.ps1
#   .\check_gpu.ps1
#   .\start.ps1
# ASR = ctranslate2 CUDA, käännökset = PyTorch CUDA (.venv)
# Varmista: NVIDIA-ajurit + CUDA Toolkit 12.x (cublas64_12.dll)

# VRAM alle ~6 GB? Käytä mediumia:
# ASR_MODEL_SIZE=medium

# Vain CPU (hidas, heikompi suomi):
# ASR_DEVICE=cpu
# ASR_MODEL_SIZE=small
# TRANSLATE_DEVICE=cpu

VAD_ENERGY_THRESHOLD=0.008
VAD_SILENCE_DURATION_MS=1500
VAD_MIN_SPEECH_DURATION_MS=1200

# Custom vocabulary (place names, domain terms) via hotwords:
# ASR_HOTWORDS=helluntai seurakunta kaupungintalo tapaaminen ...
# ASR_INITIAL_PROMPT=Tama on suomenkielinen puhe. Seurakunta, kokous, esitys, ...
